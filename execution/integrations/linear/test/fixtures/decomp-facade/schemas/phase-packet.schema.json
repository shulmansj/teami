{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "linear-decomposition-phase-packet/v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "run_id",
    "phase",
    "status",
    "reason",
    "context_digest",
    "source_refs",
    "assumptions",
    "constraints",
    "risks"
  ],
  "properties": {
    "schema_version": {
      "const": "linear-decomposition-phase-packet/v1"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "phase": {
      "enum": [
        "pm_product_sufficiency_pass",
        "sr_eng_grounding_pass",
        "pm_synthesis",
        "sr_eng_blocker_check",
        "resume"
      ]
    },
    "status": {
      "enum": [
        "continue",
        "pause",
        "needs_pm_review"
      ]
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "context_digest": {
      "type": "string",
      "minLength": 1
    },
    "source_refs": {
      "type": "array"
    },
    "assumptions": {
      "type": "array"
    },
    "constraints": {
      "type": "array"
    },
    "risks": {
      "type": "array"
    },
    "open_questions_markdown": {
      "type": "string"
    },
    "project_update_markdown": {
      "type": "string"
    },
    "technical_explanation_markdown": {
      "type": "string"
    },
    "discovery_issues": {
      "type": "array"
    },
    "final_issues": {
      "type": "array"
    }
  }
}
