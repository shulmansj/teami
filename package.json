{
  "name": "@shulmansj/teami",
  "version": "0.3.20",
  "description": "Control plane for orchestrating, evaluating, and improving agent work across a company",
  "keywords": [
    "agents",
    "workflow-automation",
    "evals",
    "linear",
    "nodejs",
    "agent-orchestration",
    "phoenix"
  ],
  "homepage": "https://github.com/shulmansj/teami#readme",
  "bugs": {
    "url": "https://github.com/shulmansj/teami/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shulmansj/teami.git"
  },
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "bin": {
    "teami": "execution/integrations/linear/cli.mjs"
  },
  "files": [
    "LICENSE",
    ".claude-plugin/plugin.json",
    "execution/engine/**/*.mjs",
    "execution/evals/**",
    "execution/integrations/git/**/*.mjs",
    "execution/integrations/linear/cli.mjs",
    "execution/integrations/linear/config.package-default.json",
    "execution/integrations/linear/mcp-server.mjs",
    "execution/integrations/linear/schemas/**",
    "execution/integrations/linear/src/**/*.mjs",
    "execution/integrations/linear/src/**/*.json"
  ],
  "scripts": {
    "init": "node execution/integrations/linear/cli.mjs init",
    "domain:add": "node execution/integrations/linear/cli.mjs domain:add",
    "doctor": "node execution/integrations/linear/cli.mjs doctor",
    "phoenix:doctor": "node execution/integrations/linear/cli.mjs phoenix:doctor",
    "phoenix:start": "node execution/integrations/linear/cli.mjs phoenix:start",
    "phoenix:stop": "node execution/integrations/linear/cli.mjs phoenix:stop",
    "phoenix:status": "node execution/integrations/linear/cli.mjs phoenix:status",
    "preflight:phoenix": "node execution/integrations/linear/cli.mjs phoenix:preflight",
    "phoenix:annotate-trace": "node execution/integrations/linear/cli.mjs phoenix:annotate-trace",
    "phoenix:promote-run": "node execution/integrations/linear/cli.mjs phoenix:promote-run",
    "phoenix:promote-decomposition": "node execution/integrations/linear/cli.mjs phoenix:promote-decomposition",
    "phoenix:experiment-decomposition": "node execution/integrations/linear/cli.mjs phoenix:experiment-decomposition",
    "phoenix:experiment-amend": "node execution/integrations/linear/cli.mjs phoenix:experiment-amend",
    "eval:decomposition": "node execution/integrations/linear/cli.mjs eval:decomposition",
    "validation:decomposition": "node execution/integrations/linear/src/decomposition-validation.mjs",
    "eval:disagreements": "node execution/integrations/linear/cli.mjs eval:disagreements",
    "eval:emit-checks": "node execution/integrations/linear/cli.mjs eval:emit-checks",
    "eval:gate": "node execution/integrations/linear/cli.mjs eval:gate",
    "eval:judge": "node execution/integrations/linear/cli.mjs eval:judge",
    "eval:register-prompt": "node execution/integrations/linear/cli.mjs eval:register-prompt",
    "eval:register-judge-prompt": "node execution/integrations/linear/cli.mjs eval:register-judge-prompt",
    "promote-candidate": "node execution/integrations/linear/cli.mjs promote-candidate",
    "draft-improvement": "node execution/integrations/linear/cli.mjs draft-improvement",
    "github:init": "node execution/integrations/linear/cli.mjs github:init",
    "security:secrets": "node scripts/security-scan.mjs tree",
    "security:secrets:history": "node scripts/security-scan.mjs history",
    "security:secrets:seed": "node scripts/security-scan.mjs seed",
    "canary:claude-plugin": "node scripts/canary-claude-plugin.mjs",
    "canary:linear-graphql": "node execution/integrations/linear/uat/status-model-e2e-uat.mjs",
    "canary:mcp-linear-setup": "node scripts/canary-mcp-linear-setup.mjs",
    "quality:static": "eslint . --max-warnings=0",
    "verify": "npm run quality:static && npm test && npm run security:secrets",
    "promotion:scan": "node execution/integrations/linear/cli.mjs promotion:scan",
    "gateway": "node execution/integrations/linear/cli.mjs gateway",
    "runner": "node execution/integrations/linear/cli.mjs gateway",
    "runtime-smoke": "node execution/integrations/linear/cli.mjs runtime-smoke",
    "uat:execution": "node execution/integrations/linear/uat/execution-uat.mjs",
    "uat:gateway": "node execution/integrations/linear/uat/gateway-uat.mjs",
    "uat:github-local": "node execution/integrations/linear/uat/github-local-uat.mjs",
    "uat:no-hosted": "node execution/integrations/linear/uat/no-hosted-uat.mjs",
    "uat:review": "node execution/integrations/linear/uat/review-uat.mjs",
    "uat:e2e-sandbox": "node execution/integrations/linear/uat/e2e-sandbox.mjs",
    "trigger-status": "node execution/integrations/linear/cli.mjs trigger-status",
    "worklist": "node execution/integrations/linear/cli.mjs worklist",
    "reset": "node execution/integrations/linear/cli.mjs reset",
    "init:linear": "node execution/integrations/linear/cli.mjs init",
    "doctor:linear": "node execution/integrations/linear/cli.mjs doctor:linear",
    "uninstall": "node execution/integrations/linear/cli.mjs uninstall",
    "uninstall:linear": "node execution/integrations/linear/cli.mjs uninstall",
    "reset:linear": "node execution/integrations/linear/cli.mjs reset",
    "test": "node execution/integrations/linear/test/run-tests.mjs"
  },
  "engines": {
    "node": ">=20.11"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.7.0"
  }
}
